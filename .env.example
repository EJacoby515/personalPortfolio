# Copy to .env for local dev. NO provider API keys belong in any VITE_ var —
# they get bundled into the public JS and can be scraped off the live site.
#
# The chatbot calls a serverless proxy (see /proxy) that holds the OpenRouter
# key server-side. Set this to the deployed Worker URL, or the local wrangler
# dev URL (http://localhost:8787) while developing.
VITE_CHAT_PROXY_URL=https://ejacoby-chat-proxy.<your-subdomain>.workers.dev
